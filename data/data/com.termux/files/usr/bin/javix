########################################
# STATUS
########################################

status_gui(){
  gui_running && echo "GUI  : running (5901)" || echo "GUI  : stopped"
}

status_ftp(){
  if ftp_running; then
    local port
    port=$(ps -o args= -p "$(pgrep -f 'tcpsvd.*ftpd' | head -1)" 2>/dev/null \
      | grep -oE '0\.0\.0\.0 [0-9]+' | awk '{print $2}')
    echo "FTP  : running (${port:-$DEFAULT_FTP_PORT})"
  else
    echo "FTP  : stopped"
  fi
}

status_java(){
  if [ -d "$JAVA_DIR" ]; then
    echo "JAVA : installed ($JAVA_DIR)"
  else
    echo "JAVA : not installed"
  fi
  java_running && echo "JAVA : process running" || echo "JAVA : no active process"
}

status_all(){
  echo
  echo "JAVIX STATUS  (v$VERSION)"
  echo "-------------------------"
  status_gui
  status_ftp
  status_java
  [ -f "$SETUP_MARKER" ] && echo "SETUP: complete" || echo "SETUP: not done"
  echo
}

########################################
# KILLALL
########################################

kill_all(){
  msg "stopping all services..."
  _ftp_kill
  _gui_kill
  ok "all services stopped"
}

########################################
# CLI
########################################

case "${1:-}" in

  start)
    case "${2:-}" in
      display|gui|vnc) start_gui ;;
      ftp|files)       shift 2; start_ftp "$@" ;;
      *)               help ;;
    esac
    ;;

  stop)
    case "${2:-}" in
      display|gui|vnc) stop_gui ;;
      ftp|files)       stop_ftp ;;
      *)               help ;;
    esac
    ;;

  restart)
    case "${2:-}" in
      display|gui|vnc) restart_gui ;;
      ftp|files)       shift 2; restart_ftp "$@" ;;
      all|"")
        restart_gui
        restart_ftp
        ;;
      *) help ;;
    esac
    ;;

  status)
    case "${2:-}" in
      display|gui|vnc) status_gui ;;
      ftp|files)       status_ftp ;;
      java)            status_java ;;
      all|"")          status_all ;;
      *)               help ;;
    esac
    ;;

  logs)
    show_logs "${2:-}"
    ;;

  setup)
    case "${2:-}" in
      check)  setup_check ;;
      reset)
        rm -f "$SETUP_MARKER"
        ok "setup marker removed — will reinstall on next run"
        ;;
      java)
        rm -f "$JAVA_DIR/.compiled"
        rm -rf "$JAVA_DIR"
        setup_java
        ;;
      "")     run_setup ;;
      *)      help ;;
    esac
    ;;

  killall)
    kill_all
    ;;

  init)
    case "${2:-}" in
      java) init_java ;;
      *)    help ;;
    esac
    ;;

  --version|-v)
    echo "javix $VERSION"
    ;;

  help|--help|-h)
    help
    ;;

  *)
    help
    ;;

esac
